---
import Layout from "../layouts/Layout.astro";
import PlanetCard from "../components/PlanetCard.astro";
import PlanetScene from "../components/PlanetScene.astro";
---

<Layout title="Exoplanet Archive - NASA Data">
  <main class="h-screen w-screen overflow-hidden relative bg-black">
    <PlanetScene planet={null} />

    <div
      class="absolute inset-0 z-20 pointer-events-none flex flex-col justify-between p-12 md:p-16"
    >
      <PlanetCard planet={null} />

      <div
        class="absolute right-12 md:right-16 z-30 flex gap-4 top-1/2 -translate-y-1/2 pointer-events-auto"
      >
        <button
          id="prev-planet"
          class="group flex items-center justify-center w-14 h-14 border border-white/20 rounded-full hover:border-white/60 transition-all active:scale-95 bg-black/20 backdrop-blur-sm"
        >
          <span
            class="text-white opacity-40 group-hover:opacity-100 transition-opacity"
            >←</span
          >
        </button>
        <button
          id="next-planet"
          class="group flex items-center justify-center w-14 h-14 border border-white/20 rounded-full hover:border-white/60 transition-all active:scale-95 bg-black/20 backdrop-blur-sm"
        >
          <span
            class="text-white opacity-40 group-hover:opacity-100 transition-opacity"
            >→</span
          >
        </button>
      </div>
    </div>
  </main>
</Layout>

<script>
  import type { Planet } from "../types/planet";

  let planets: Planet[] = [];
  let currentIndex = 0;
  let offset = 5;
  let isFetching = false;

  async function init() {
    showLoading();
    try {
      const res = await fetch("/api/planets?offset=0");

      if (!res.ok) {
        const errorData = await res.json();
        console.error("Detalle del error desde el proxy:", errorData);
        throw new Error("Error en mi proxy");
      }

      planets = await res.json();
      if (planets.length > 0) renderPlanet(planets[0]);
    } catch (e) {
      console.error("Fallo total:", e);
    } finally {
      hideLoading();
    }
  }

  // --- LÓGICA DE RENDERIZADO ---
  function get(field: string) {
    return document.querySelector(`[data-field="${field}"]`);
  }

  function renderPlanet(planet: Planet) {
    if (!planet) return;

    const distLY = planet.sy_dist ? (planet.sy_dist * 3.262).toFixed(1) : "???";
    const orbitDays = planet.pl_orbper?.toFixed(1) ?? "---";
    const isHot = (planet.pl_eqt ?? 0) > 500;

    const fields = {
      pl_name: planet.pl_name ?? "???",
      disc_year: planet.disc_year?.toString() ?? "???",
      pl_rade: planet.pl_rade?.toFixed(2) ?? "---",
      pl_masse: planet.pl_masse?.toFixed(2) ?? "---",
      pl_dens: planet.pl_dens?.toFixed(2) ?? "---",
      pl_eqt: planet.pl_eqt?.toString() ?? "---",
      pl_orbper: orbitDays,
      discoverymethod: planet.discoverymethod ?? "???",
      sy_dist: distLY,
    };

    Object.entries(fields).forEach(([key, value]) => {
      const el = get(key);
      if (el) el.textContent = value;
    });

    const eqtEl = get("pl_eqt")?.parentElement;
    if (eqtEl) {
      eqtEl.className = `text-3xl font-light ${isHot ? "text-amber-400" : "text-white"}`;
    }

    if ((window as any).updateScene) {
      (window as any).updateScene(planet);
    }
  }

  // --- GESTIÓN DE CARGA ---
  function showLoading() {
    const screen = document.getElementById("loading-screen");
    if (screen) {
      screen.style.pointerEvents = "all";
      screen.style.opacity = "1";
    }
  }

  function hideLoading() {
    const screen = document.getElementById("loading-screen");
    if (screen) {
      screen.style.opacity = "0";
      screen.style.pointerEvents = "none";
    }
  }

  // --- CARGA INFINITA (Pagination) ---
  async function fetchMore() {
    if (isFetching) return;
    isFetching = true;

    const currentOffset = planets.length;

    try {
      const res = await fetch(`/api/planets?offset=${currentOffset}`);
      if (!res.ok) throw new Error("Proxy error");

      const allPlanetsFetched = await res.json();

      const existingNames = new Set(planets.map((p) => p.pl_name));
      const newOnes = allPlanetsFetched.filter(
        (p: Planet) => !existingNames.has(p.pl_name),
      );

      if (newOnes.length > 0) {
        planets = [...planets, ...newOnes];
        console.log(
          "Añadidos:",
          newOnes.length,
          "Total en memoria:",
          planets.length,
        );
      }
    } catch (e) {
      console.error(e);
    } finally {
      isFetching = false;
    }
  }

  // --- EVENT LISTENERS ---
  document
    .getElementById("next-planet")
    ?.addEventListener("click", async () => {
      if (planets.length === 0) return;

      if (currentIndex >= planets.length - 3) fetchMore();

      if (currentIndex < planets.length - 1) {
        currentIndex++;
        renderPlanet(planets[currentIndex]);
      } else {
        showLoading();
        await fetchMore();
        if (currentIndex < planets.length - 1) {
          currentIndex++;
          renderPlanet(planets[currentIndex]);
        }
        hideLoading();
      }
    });

  document.getElementById("prev-planet")?.addEventListener("click", () => {
    if (currentIndex > 0) {
      currentIndex--;
      renderPlanet(planets[currentIndex]);
    }
  });

  init();
</script>
