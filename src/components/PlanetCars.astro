---
const { planet } = Astro.props;

const distLY = (planet.sy_dist * 3.262).toFixed(1);
const orbitDays = planet.pl_orbper?.toFixed(1) || "---";
const isHot = planet.pl_eqt > 500;
---

<section
  class="w-screen h-screen relative flex items-center justify-center snap-start"
>
  <div class="absolute left-12 top-12 md:left-16 md:top-16 text-white z-20">
    <p class="text-[10px] font-mono opacity-40 uppercase tracking-[0.4em] mb-1">
      Nombre_Id
    </p>
    <h1
      class="text-5xl md:text-7xl font-light italic tracking-tighter uppercase leading-none"
    >
      {planet.pl_name ? planet.pl_name : "???"}
    </h1>
    <h3 class="text-lg font-mono opacity-60 mt-2">
      Año_descubrimiento: <span class="text-white"
        >{planet.disc_year ? planet.disc_year : "???"}
      </span>
    </h3>
  </div>

  <div
    class="absolute right-12 top-12 md:right-16 md:top-16 text-right text-white z-20"
  >
    <p class="text-[10px] font-mono opacity-40 uppercase tracking-[0.4em] mb-1">
      Duración_año
    </p>
    <div class="flex items-baseline justify-end gap-2">
      <span class="text-4xl font-light">{orbitDays ? orbitDays : "???"}</span>
      <span class="text-xs font-mono opacity-60 uppercase">Days</span>
    </div>
  </div>

  <div
    class="absolute left-12 bottom-12 md:left-16 md:bottom-16 text-white z-20"
  >
    <p class="text-[10px] font-mono opacity-40 uppercase tracking-[0.4em] mb-1">
      Metodo_detección
    </p>
    <p
      class="text-xl font-light tracking-wide uppercase border-l-2 border-white pl-4"
    >
      {planet.discoverymethod ? planet.discoverymethod : "???"}
    </p>
  </div>

  <div
    class="absolute right-12 bottom-12 md:right-16 md:bottom-16 text-right text-white z-20"
  >
    <p class="text-[10px] font-mono opacity-40 uppercase tracking-[0.4em] mb-1">
      Distacia_sol
    </p>
    <div class="flex items-baseline justify-end gap-2">
      <span class="text-4xl font-light"> {distLY ? distLY : "???"}</span>
      <span class="text-xs font-mono opacity-60 uppercase">Años_luz</span>
    </div>
  </div>

  <div class="relative flex items-center justify-center">
    <div
      class="w-72 h-72 rounded-full border border-white/10 flex items-center justify-center relative z-10 shadow-[0_0_50px_rgba(255,255,255,0.05)]"
    >
      <span class="text-[10px] font-mono opacity-20 tracking-widest uppercase"
        >Galería</span
      >

      <div class="absolute -left-40 bottom-0 text-right space-y-4 w-32">
        <div class="border-r border-white/40 pr-3">
          <p class="text-[9px] font-mono opacity-40 uppercase">Densidad</p>
          <p class="text-lg text-white font-light">
            {planet.pl_dens?.toFixed(2) || "---"}
          </p>
        </div>
        <div class="border-r border-white/40 pr-3">
          <p class="text-[9px] font-mono opacity-40 uppercase">Temperatura</p>
          <p
            class={`text-lg font-light ${isHot ? "text-amber-400" : "text-white"}`}
          >
            {planet.pl_eqt || "---"} K
          </p>
        </div>
      </div>

      <div class="absolute -right-40 bottom-8 text-left w-32">
        <div class="border-l border-white/40 pl-3">
          <p class="text-[9px] font-mono opacity-40 uppercase">Radio</p>
          <p class="text-2xl text-white font-light">
            {planet.pl_rade?.toFixed(2) || "---"}
            <span class="text-[10px] opacity-50">R⊕</span>
          </p>
        </div>
      </div>
    </div>
    <div class="absolute -bottom-16 left-1/2 -translate-x-1/2 text-center w-40">
      <div class="border-t border-white/40 pt-2">
        <p class="text-[9px] font-mono opacity-40 uppercase tracking-widest">
          Masa
        </p>
        <p class="text-xl text-white font-light">
          {planet.pl_masse?.toFixed(2) || "---"}
          <span class="text-[10px] opacity-50 ml-1">M⊕</span>
        </p>
      </div>
    </div>
  </div>
</section>
