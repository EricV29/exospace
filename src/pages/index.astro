---
import Layout from "../layouts/Layout.astro";
import PlanetGallery from "../components/PlanetCard.tsx";

const API_URL =
  "https://exoplanetarchive.ipac.caltech.edu/TAP/sync?query=select+top+5+pl_name,discoverymethod,pl_orbper,pl_dens,pl_eqt,sy_snum,sy_dist,disc_year,pl_rade,pl_masse+from+ps+order+by+disc_year+desc&format=json";

const response = await fetch(API_URL);
const initialPlanets = await response.json();
---

<Layout>
  <main class="h-screen w-screen overflow-hidden">
    <PlanetGallery client:load initialPlanets={initialPlanets} />
  </main>
</Layout>
