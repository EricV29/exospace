<svg
  viewBox="0 0 50 50"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  class="cursor-svg"
>
  <circle
    cx="25"
    cy="25"
    r="20"
    stroke="white"
    stroke-width="1.5"
    stroke-dasharray="26 5"
    stroke-linecap="round"></circle>
  <circle cx="25" cy="25" r="1.5" fill="white"></circle>
</svg>

<style is:global>
  .cursor-svg {
    width: 100%;
    height: 100%;
    animation: rotate-hud 6s linear infinite;
  }

  @keyframes rotate-hud {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }
</style>
